# 飞书应用凭证（必填）
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# 飞书 Wiki 配置
FEISHU_WIKI_SPACE_ID=your_wiki_space_id_here
FEISHU_WIKI_PARENT_NODE_TOKEN=
# 留空则上传到知识库根部；填写则上传到指定子节点下
# 获取方式：打开目标页面，从 URL 中提取 token
#   https://xxx.feishu.cn/wiki/ABC123  →  ABC123

# 待上传的文档目录
FEISHU_MARKDOWN_DIR=../docs
# 默认 ../docs，指向语雀导出输出目录
